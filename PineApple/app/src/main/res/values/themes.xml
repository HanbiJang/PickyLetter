<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.PineApple" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">#FFDCCC</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/pickyBlue</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>

        <!--타이틀바 숨기기 / 상태바 색상 바꾸기       -->
        <item name="windowNoTitle">true</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <item name="android:statusBarColor" tools:targetApi="lollipop">@color/pickyCoral</item>

    </style>

    <style name="AnimationPopupStyle">
        <item name="android:windowEnterAnimation">@anim/bottom_up</item>
        <item name="android:windowShowAnimation">@anim/bottom_up</item>
        <item name="android:windowExitAnimation">@anim/bottom_down</item>
    </style>

    <style name="AnimationPopupLoadingStyle">
        <item name="android:windowEnterAnimation">@anim/enter_big</item>
        <item name="android:windowShowAnimation">@anim/enter_big</item>
        <item name="android:windowExitAnimation">@anim/exit_small</item>
    </style>

<!--    <style name="EditTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorAccent">@color/pickyGray</item>
    </style>-->


</resources>