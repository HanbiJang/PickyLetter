<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="500dp"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@drawable/round_squre_top"
    android:paddingLeft="16dp"
    android:paddingRight="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="20dp">

        <TextView
            android:layout_width="233dp"
            android:layout_height="18.4dp"
            android:textSize="16sp"
            android:text="Filter"
            android:layout_weight="1"
            android:textColor="@color/pickyGray"
            android:gravity="center"/>

        <FrameLayout
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginRight="19dp">

            <Button
                android:layout_width="21dp"
                android:layout_height="14dp"
                android:layout_gravity="right"
                android:layout_marginTop="3dp"

                android:background="@drawable/btn_check"/>

        </FrameLayout>


    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="브랜드"
        android:textColor="@color/pickyGray"
        android:fontFamily="@font/no_b"
        android:includeFontPadding="false"
        android:textSize="18sp"
        android:layout_marginTop="32dp"/>


    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_marginTop="7.7dp"
        android:background="@color/pickyGray"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_filter_brand"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="15.5dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="기간"
        android:textColor="@color/pickyGray"
        android:fontFamily="@font/no_b"
        android:includeFontPadding="false"
        android:textSize="18sp"
        android:layout_marginTop="32dp"/>


    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_marginTop="7.7dp"
        android:background="@color/pickyGray"/>

    <LinearLayout
        android:layout_width="50dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="15.5dp">

        <Button
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:background="@drawable/square_check_fill"
            app:backgroundTintMode="multiply"
            android:layout_marginTop="3dp"
            android:layout_marginRight="5dp"
            app:backgroundTint="@color/white" />

        <TextView
            android:layout_width="50sp"
            android:layout_height="wrap_content"
            android:text="기간"
            android:textColor="@color/pickyGray"
            android:fontFamily="@font/no_m"
            android:includeFontPadding="false"
            android:layout_gravity="center"
            android:textSize="14sp" />

    </LinearLayout>



    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="11.2dp"
        android:layout_marginBottom="40dp">

        <FrameLayout
            android:layout_width="153dp"
            android:layout_height="78dp"
            android:background="@drawable/round_squre"
            android:layout_weight="1"
            android:backgroundTint="@color/pickyUnableGray"
            android:backgroundTintMode="screen"
            android:padding="15dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="시작"
                    android:textSize="11sp"
                    android:textColor="@color/pickyGray"
                    android:fontFamily="@font/no_r"
                    android:includeFontPadding="false"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="15"
                        android:textSize="24sp"
                        android:textColor="@color/pickyGray"
                        android:fontFamily="@font/no_b"
                        android:includeFontPadding="false"/>
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginLeft="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2021년 2월"
                            android:textSize="11sp"
                            android:textColor="@color/pickyGray"
                            android:fontFamily="@font/no_r"
                            android:includeFontPadding="false"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="월요일"
                            android:textSize="11sp"
                            android:textColor="@color/pickyGray"
                            android:fontFamily="@font/no_r"
                            android:includeFontPadding="false"/>

                    </LinearLayout>

                    <FrameLayout
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_marginLeft="14dp"
                        >

                        <Button
                            android:layout_width="12dp"
                            android:layout_height="6dp"
                            android:background="@drawable/btn_drop_unablegray"
                            android:layout_gravity="center"
                            />


                    </FrameLayout>

                </LinearLayout>

            </LinearLayout>


        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:textColor="@color/pickyGray"
            android:text=" - "
            android:gravity="center"
            android:textSize="30dp"
            android:fontFamily="@font/no_r"
            android:includeFontPadding="false"/>

        <FrameLayout
            android:layout_width="153dp"
            android:layout_height="78dp"
            android:background="@drawable/round_squre"
            android:layout_weight="1"
            android:backgroundTint="@color/pickyUnableGray"
            android:backgroundTintMode="screen"
            android:padding="15dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="종료"
                    android:textSize="11sp"
                    android:textColor="@color/pickyGray"
                    android:fontFamily="@font/no_r"
                    android:includeFontPadding="false"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="22"
                        android:textSize="24sp"
                        android:textColor="@color/pickyGray"
                        android:fontFamily="@font/no_b"
                        android:includeFontPadding="false"/>
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginLeft="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2021년 2월"
                            android:textSize="11sp"
                            android:textColor="@color/pickyGray"
                            android:fontFamily="@font/no_r"
                            android:includeFontPadding="false"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="월요일"
                            android:textSize="11sp"
                            android:textColor="@color/pickyGray"
                            android:fontFamily="@font/no_r"
                            android:includeFontPadding="false"/>

                    </LinearLayout>

                    <FrameLayout
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_marginLeft="14dp"
                        >

                        <Button
                            android:layout_width="12dp"
                            android:layout_height="6dp"
                            android:background="@drawable/btn_drop_unablegray"
                            android:layout_gravity="center"
                            />


                    </FrameLayout>

                </LinearLayout>

            </LinearLayout>
            





        </FrameLayout>

    </LinearLayout>



</LinearLayout>