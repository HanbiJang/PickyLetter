<?xml version="1.0" encoding="utf-8"?>
        <LinearLayout
            xmlns:android="http://schemas.android.com/apk/res/android"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="254dp"
            android:layout_height="153dp"
            android:background="@drawable/round_squre"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="105dp"
                android:orientation="vertical"
                android:layout_gravity="center"
                android:padding="10dp">

                <TextView
                    android:id="@+id/tv_brand"
                    android:layout_width="235dp"
                    android:layout_height="85dp"
                    android:gravity="center"
                    android:textSize="13sp"
                    android:textColor="@color/pickyGray"
                    android:text="오렌지레터를\n정말 구독 해지하시겠어요?"
                    android:fontFamily="@font/no_m"
                    android:includeFontPadding="false"/>


            </LinearLayout>


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_yes"
                    android:layout_width="wrap_content"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:background="@drawable/btn_popup_round_squre_left"
                    android:backgroundTint="@color/pickyGray"
                    android:fontFamily="@font/no_m"
                    android:includeFontPadding="false"
                    android:text="해지할래요"
                    android:textColor="@color/white"
                    android:textSize="14sp"></Button>

                <Button
                    android:id="@+id/btn_no"
                    android:layout_width="wrap_content"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:background="@drawable/btn_popup_round_squre_right"
                    android:fontFamily="@font/no_m"

                    android:includeFontPadding="false"
                    android:text="구독할래요"

                    android:textColor="@color/pickyGray"
                    android:textSize="14sp"
                    app:backgroundTint="@color/white"
                    app:backgroundTintMode="multiply"></Button>


            </LinearLayout>

        </LinearLayout>

