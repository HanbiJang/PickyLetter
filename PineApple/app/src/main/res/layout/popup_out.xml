<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="254dp"
    android:layout_height="156dp"
    android:background="#00ff0000"
    app:backgroundTintMode="multiply"
    app:backgroundTint="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/round_squre"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="87dp"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="10dp">


                <TextView
                    android:id="@+id/textView10"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textSize="14sp"
                    android:textColor="@color/pickyGray"
                    android:text="\n정말 탈퇴하실 건가요?"
                    android:fontFamily="@font/no_m"
                    android:includeFontPadding="false"/>


            </LinearLayout>


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="bottom"
                android:layout_marginTop="1dp">

                <Button
                    android:id="@+id/btn_yes"
                    android:layout_width="wrap_content"
                    android:layout_height="43dp"
                    android:text="탈퇴할래요"
                    android:fontFamily="@font/no_m"
                    android:includeFontPadding="false"
                    android:textSize="14sp"
                    android:textColor="@color/white"
                    android:background="@drawable/btn_popup_round_squre_left"
                    android:backgroundTint="@color/pickyGray"
                    android:layout_weight="1"></Button>

                <Button
                    android:id="@+id/btn_no"
                    android:layout_width="wrap_content"
                    android:layout_height="43dp"
                    android:text=" 안할래요"
                    android:fontFamily="@font/no_m"
                    android:includeFontPadding="false"
                    android:background="@drawable/btn_popup_round_squre_right"

                    app:backgroundTintMode="multiply"
                    app:backgroundTint="@color/white"

                    android:textSize="14sp"
                    android:textColor="@color/pickyGray"
                    android:layout_weight="1"></Button>


            </LinearLayout>

        </LinearLayout>


    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>