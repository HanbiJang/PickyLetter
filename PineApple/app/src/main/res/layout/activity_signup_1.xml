<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/white">

    <TextView
        android:layout_width="328dp"
        android:layout_height="70dp"
        android:layout_marginTop="84dp"
        android:fontFamily="@font/no_b"
        android:includeFontPadding="false"
        android:text="안녕하세요\n이름이 어떻게 되시나요?"
        android:textColor="@color/pickyGray"
        android:textSize="22sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />


    <TextView
        android:id="@+id/tv_name"
        android:layout_width="328dp"
        android:layout_height="63dp"
        android:layout_marginTop="187dp"
        android:fontFamily="@font/no_r"
        android:includeFontPadding="false"
        android:text="이름"
        android:textColor="@color/subtitle_gray"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <EditText
        android:id="@+id/et_name"
        android:layout_width="328dp"
        android:layout_height="63dp"
        android:layout_marginTop="210dp"
        android:fontFamily="@font/no_m"
        android:includeFontPadding="false"
        android:hint="이름을 입력해주세요"
        android:textColorHint="@color/pickyUnableGray"
        android:textColor="@color/pickyGray"
        android:textSize="18sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />


    <Button
        android:id="@+id/btn_next"
        android:layout_width="328dp"
        android:layout_height="48dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="547dp"
        android:background="@drawable/round_squre_gray"
        app:backgroundTintMode="multiply"
        app:backgroundTint="@color/white"
        android:text="다음"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:fontFamily="@font/no_r"
        android:includeFontPadding="false"
        />

    <LinearLayout
        android:id="@+id/ll_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="@id/tv_name"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="187dp"
        android:visibility="invisible">

        <ImageView
            android:id="@+id/img_warning"
            android:layout_width="13dp"
            android:layout_height="11dp"
            android:src="@drawable/warning"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/pickyRed"
            android:fontFamily="@font/no_r"
            android:includeFontPadding="false"
            android:layout_marginLeft="6dp"
            android:text="올바른 이름을 입력해주세요"/>

    </LinearLayout>



</androidx.constraintlayout.widget.ConstraintLayout>