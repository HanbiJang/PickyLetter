<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="6.3pt">


    <FrameLayout

        android:id="@+id/fr_1"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/round_squre"
        android:padding="1dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="5dp"
            app:cardElevation="5dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:id="@+id/linearLayout2"
                    android:layout_width="match_parent"
                    android:layout_height="93dp"
                    android:orientation="horizontal"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <LinearLayout
                        android:layout_width="100dp"
                        android:layout_height="match_parent"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/imageView"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/newspic" />


                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:layout_centerInParent="true"
                        android:background="#000000" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="15dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_title_rank"
                            android:layout_width="187.8dp"
                            android:layout_height="wrap_content"
                            android:text="팬톤, 올해의 컬러 팬톤 올해의 컬러"
                            android:fontFamily="@font/no_b"
                            android:includeFontPadding="false"
                            android:textColor="#000000"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginTop="5dp"
                            android:gravity="center|left"
                            android:orientation="horizontal">

                            <ImageView
                                android:id="@+id/imageView2"
                                android:layout_width="8pt"
                                android:layout_height="8pt"
                                android:layout_marginRight="5dp"
                                android:background="@drawable/round_circle" />

                            <TextView
                                android:id="@+id/tv_brand"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="디독 | "
                                android:fontFamily="@font/no_r"
                                android:includeFontPadding="false"
                                android:textColor="#000000"
                                android:textSize="4pt" />


                            <TextView
                                android:id="@+id/tv_date"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="02/01/2021"
                                android:fontFamily="@font/no_r"
                                android:includeFontPadding="false"
                                android:textColor="#000000"
                                android:textSize="4pt" />
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>

                <FrameLayout
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginEnd="10dp"
                    android:layout_marginRight="10dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <Button
                        android:id="@+id/btn_bookmark_rank"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:background="@drawable/btn_bookmark"
                        app:backgroundTintMode="multiply"
                        app:backgroundTint="#FFFFFF"
                        android:text="북마크" />
                </FrameLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.cardview.widget.CardView>

    </FrameLayout>

    <FrameLayout
        android:layout_width="11pt"
        android:layout_height="11pt"
        android:background="@drawable/round_squre_rank"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/fr_1">

        <TextView
            android:id="@+id/tv_num_rank"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="3"
            android:fontFamily="@font/po_m"
            android:includeFontPadding="false"
            android:textSize="4pt"
            android:textColor="@color/pickyGray"/>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>