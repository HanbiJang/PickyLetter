<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".home.Fragment1_Home"

    >

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/white"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/pickyCoral"
                android:orientation="vertical">


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="36.7dp"
                    android:layout_marginBottom="20dp"
                    android:paddingLeft="16dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tv_nickname"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/no_b"
                            android:text="파인애플"
                            android:textColor="#000000"
                            android:includeFontPadding="false"
                            android:textSize="24sp" />

                        <TextView
                            android:id="@+id/tv_empty"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/no_b"
                            android:text="아직 아무 레터도\n도착하지 않았어요!"
                            android:textColor="#000000"
                            android:includeFontPadding="false"
                            android:textSize="22sp"
                            android:visibility="gone"/>

                        <TextView
                            android:id="@+id/tv_nim"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="님,"
                            android:includeFontPadding="false"
                            android:fontFamily="@font/no_m"
                            android:textColor="#000000"
                            android:textSize="22sp"
                            />


                    </LinearLayout>



                <TextView
                    android:id="@+id/tv_dochack"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="최근 한주간 도착한 레터예요!"
                    android:fontFamily="@font/no_m"
                    android:includeFontPadding="false"
                    android:textColor="#000000"
                    android:textSize="22sp" />

                </LinearLayout>


                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_newletter"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginBottom="20dp"
                    android:visibility="visible"/>

                <ImageView
                    android:id="@+id/img_empty"
                    android:layout_width="188dp"
                    android:layout_height="182dp"
                    android:src="@drawable/picky_letter_empty"
                    android:layout_gravity="center"
                    android:layout_marginTop="32dp"
                    android:layout_marginBottom="27dp"
                    android:visibility="gone"/>


            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_centerInParent="true"
                android:background="#000000"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:layout_marginLeft="6.3pt"
                    android:layout_marginTop="10.3pt"
                    android:background="@color/white">

                    <TextView
                        android:id="@+id/textView5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="7"
                        android:text="지난 레터"
                        android:includeFontPadding="false"
                        android:fontFamily="@font/no_b"
                        android:textColor="#000000"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8pt"/>

                    <FrameLayout
                        android:id="@+id/fl_btn_filter"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginRight="16dp"
                        android:layout_gravity="center"
                        android:padding="1dp">

                        <Button
                            android:id="@+id/btn_filter"
                            android:layout_width="20dp"
                            android:layout_height="18dp"
                            android:layout_gravity="right"
                            android:background="@drawable/btn_filter"
                            app:backgroundTint="@color/white"
                            app:backgroundTintMode="multiply"/>

                    </FrameLayout>


                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_oldletter"
                    android:layout_width="match_parent"
                    android:layout_height="500dp"
                    android:layout_marginLeft="6.3pt"
                    android:background="@color/white"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:orientation="vertical"
                    android:layout_marginTop="50dp"
                    android:background="@color/white">

                </LinearLayout>
            </LinearLayout>

    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>