<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/white">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="315dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:background="@color/white">

                <ImageView
                    android:id="@+id/img_news"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@color/pickyUnableGray"/>

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#4D333333"
                    android:scaleType="centerCrop" />
            </FrameLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="315dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

            </FrameLayout>


            <FrameLayout
                android:id="@+id/fl_btn_back"
                android:layout_width="30dp"
                android:layout_height="30dp"

                android:layout_marginTop="59dp"
                android:layout_marginLeft="17dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <Button
                    android:id="@+id/btn_back"
                    android:layout_width="7dp"
                    android:layout_height="14dp"
                    android:background="@drawable/btn_back"
                    app:backgroundTint="@color/white"/>

            </FrameLayout>

            <Button
                android:id="@+id/btn_bookmark"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/btn_bookmark_line"
                app:backgroundTint="@color/white"
                app:backgroundTintMode="multiply"

                android:layout_marginTop="59dp"
                android:layout_marginRight="16dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:visibility="visible"/>

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="320dp"
                android:layout_height="67dp"
                android:layout_marginTop="190dp"
                android:fontFamily="@font/no_b"
                android:text="팬톤, 올해의 컬러에 담긴 메시지 팬톤, 올해의 컬러에 담긴 메시지"
                android:includeFontPadding="false"
                android:textColor="@color/white"
                android:textSize="22sp"

                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_marginLeft="18dp"/>

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/cimg_brand"
                    android:layout_width="31dp"
                    android:layout_height="31dp"
                    android:layout_marginLeft="16dp"
                    android:layout_marginTop="270dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"

                    app:civ_border_color="@color/pickyGray"
                    app:civ_border_width="2dp"
                    android:src="@drawable/brand_1"/>


            <TextView
                android:id="@+id/tv_brand"
                android:layout_width="320dp"
                android:layout_height="wrap_content"

                android:fontFamily="@font/no_r"
                android:text="디독"
                android:includeFontPadding="false"
                android:textColor="@color/white"
                android:textSize="14sp"

                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_marginLeft="54.4dp"
                android:layout_marginTop="274.4dp"
                />

            <TextView
                android:id="@+id/tv_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"

                android:fontFamily="@font/no_r"
                android:text="02/01/2021"
                android:includeFontPadding="false"
                android:textColor="@color/white"
                android:textSize="14sp"

                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_marginTop="274.4dp"
                android:layout_marginRight="16dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="@color/pickyGray"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_marginTop="315dp"
                />

            <WebView
                android:id="@+id/wv_news"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_marginTop="316dp"
                android:background="@color/white"
                android:nestedScrollingEnabled="false"/>



        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>