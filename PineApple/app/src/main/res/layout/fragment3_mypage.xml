<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    android:id="@+id/sr_layout"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    tools:context=".mypage_settings.settings.SettingsMain"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    tools:context=".mypage_settings.mypage.Fragment3_MyPage"
    android:layout_marginRight="16dp"
    android:layout_marginLeft="16dp"
    android:background="@color/white">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="39dp"
        android:background="@color/white"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/imageView4"
            android:layout_width="46.1dp"
            android:layout_height="46.1dp"
            android:background="@drawable/img_profile"
            android:layout_marginRight="7.7dp"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/white"
            android:layout_weight="1">

            <TextView
                android:id="@+id/tv_nickname"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="파인애플"
                android:fontFamily="@font/no_b"
                android:includeFontPadding="false"
                android:textColor="@color/pickyGray"
                android:textSize="18sp"/>

            <TextView
                android:id="@+id/tv_email"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="makeus.pineapple@gmail.com"
                android:fontFamily="@font/no_m"
                android:includeFontPadding="false"
                android:textColor="@color/pickyGray"
                android:textSize="12sp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="@color/white"
            android:gravity="top">

            <FrameLayout
                android:id="@+id/fl_btn_setting"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_gravity="center">

                <Button
                    android:id="@+id/btn_setting"
                    android:layout_width="17.3dp"
                    android:layout_height="17.3dp"
                    android:layout_gravity="right"
                    android:background="@drawable/btn_setting_line"
                    android:text="settings" />
            </FrameLayout>

        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_centerInParent="true"
        android:layout_marginTop="14.2dp"
        android:layout_marginBottom="30.4dp"
        android:background="#000000"/>

    <TextView
        android:id="@+id/tv_bookmarknum"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="나의 북마크 (7)"
        android:fontFamily="@font/no_b"
        android:includeFontPadding="false"
        android:textColor="@color/pickyGray"
        android:layout_marginBottom="24dp"
        android:background="@color/white"
        android:textSize="18sp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_mypage_bookmark"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white"
        android:layout_marginBottom="10dp"/>


</LinearLayout>
</LinearLayout>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>