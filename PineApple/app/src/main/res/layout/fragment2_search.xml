<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".search.Fragment2_Search"
    android:background="@color/white">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:background="@color/white"
            android:orientation="vertical"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:id="@+id/ll_search"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="58dp"
                android:background="@drawable/round_squre"
                android:orientation="horizontal"
                android:paddingLeft="10dp">

                <FrameLayout
                    android:id="@+id/fl_btn_search"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_gravity="center">

                    <Button
                        android:id="@+id/btn_search"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_gravity="center"
                        android:background="@drawable/btn_search_search"
                        android:backgroundTint="@color/white"
                        android:backgroundTintMode="multiply" />

                </FrameLayout>


                <EditText
                    android:id="@+id/et_search"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="1dp"
                    android:layout_weight="9"
                    android:background="@drawable/round_squre_search"
                    android:fontFamily="@font/no_m"
                    android:hint="궁금한 뉴스레터를 검색하세요"
                    android:includeFontPadding="false"
                    android:inputType="textPersonName"
                    android:padding="10dp"
                    android:textColor="@color/pickyGray"
                    android:textColorHint="@color/pickyUnableGray"
                    android:textSize="12sp">

                </EditText>

                <FrameLayout
                    android:id="@+id/fl_btn_x"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_gravity="center"
                    android:layout_marginRight="14.8dp">


                    <Button
                        android:id="@+id/btn_x"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_gravity="center"
                        android:background="@drawable/btn_search_x"
                        android:backgroundTint="@color/white"
                        android:backgroundTintMode="multiply" />

                </FrameLayout>


            </LinearLayout>

            <LinearLayout
                android:id="@+id/ll_search_result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_search_result"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:text=" '팬톤컬러' 검색결과"
                    android:textColor="@color/pickyGray"

                    android:fontFamily="@font/no_b"
                    android:includeFontPadding="false"
                    android:textSize="18sp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_search_result"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="8dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/textView2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:fontFamily="@font/no_b"
                    android:includeFontPadding="false"
                    android:text="많은 유저들이 북마크했어요!"
                    android:textColor="@color/pickyGray"
                    android:textSize="18sp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_rank"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="100dp" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>